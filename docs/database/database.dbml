// =============================================
// HỆ THỐNG TÌM KIẾM VIỆC LÀM & ĐĂNG TUYỂN NHÂN SỰ (TINH GỌN)
// Database: PostgreSQL
// Phiên bản: 2.0 (Simplified)
// =============================================

Project job_matching_simplified {
  database_type: 'PostgreSQL'
  Note: '''
    # Hệ Thống Tìm Kiếm Việc Làm & Đăng Tuyển Nhân Sự (Rút Gọn)
    Hệ thống quản lý tuyển dụng tinh gọn tập trung vào lõi Đăng tuyển & Tìm việc:
    - Users: Người dùng chung (Ứng viên, Nhà tuyển dụng, Admin). Với Nhà tuyển dụng, thông tin công ty được lưu trực tiếp tại bảng này.
    - Candidate Profiles: Hồ sơ ứng viên, lưu trữ CV, học vấn, kinh nghiệm (dạng JSONB) và kỹ năng (dạng TEXT[]).
    - Jobs: Tin tuyển dụng, lưu kỹ năng yêu cầu (TEXT[]), ngành nghề và khu vực (VARCHAR).
    - Applications: Đơn ứng tuyển nộp kèm CV thời điểm ứng tuyển.
    - Saved Jobs: Việc làm đã lưu.
    - Notifications: Thông báo hệ thống.
    - User Tokens: Quản lý phiên làm việc đa thiết bị.
  '''
}

// =============================================
// ENUM DEFINITIONS
// =============================================

Enum user_role {
  candidate [note: 'Ứng viên']
  employer [note: 'Nhà tuyển dụng']
  admin [note: 'Quản trị viên']
}

Enum user_status {
  active [note: 'Đang hoạt động']
  inactive [note: 'Không hoạt động']
  banned [note: 'Bị khóa']
}

Enum job_type {
  "Toàn thời gian"
  "Bán thời gian"
  "Làm từ xa"
  "Freelance"
  "Thực tập"
}

Enum job_status {
  draft [note: 'Bản nháp']
  active [note: 'Đang tuyển']
  paused [note: 'Tạm dừng']
  closed [note: 'Đã đóng']
}

Enum application_status {
  submitted [note: 'Đã nộp']
  reviewing [note: 'Đang xem xét']
  shortlisted [note: 'Phỏng vấn']
  hired [note: 'Đã tuyển']
  rejected [note: 'Bị từ chối']
}

Enum notification_type {
  application [note: 'Liên quan đơn ứng tuyển']
  job_match [note: 'Việc làm phù hợp']
  system [note: 'Thông báo hệ thống']
}

// =============================================
// TABLES DEFINITIONS
// =============================================

Table companies {
  id int [pk, increment, note: 'ID công ty']
  name varchar(255) [not null, note: 'Tên công ty']
  logo varchar(500) [note: 'URL Logo công ty']
  website varchar(255) [note: 'Website công ty']
  address varchar(255) [note: 'Địa chỉ công ty']
  description text [note: 'Mô tả chi tiết công ty']
  size varchar(50) [note: 'Quy mô công ty (Ví dụ: 10-50 nhân viên)']
  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo công ty']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật gần nhất']

  Note: 'Thông tin công ty đăng ký trên hệ thống.'

  indexes {
    name [name: 'idx_companies_name']
  }
}

Table users {
  id int [pk, increment, note: 'ID người dùng']
  email varchar(255) [unique, not null, note: 'Email đăng nhập']
  password_hash varchar(255) [not null, note: 'Mật khẩu mã hóa']
  full_name varchar(100) [not null, note: 'Họ và tên']
  phone varchar(20) [note: 'Số điện thoại']
  avatar_url varchar(500) [note: 'URL ảnh đại diện']
  role user_role [not null, note: 'Vai trò: candidate | employer | admin']
  status user_status [not null, default: 'active', note: 'Trạng thái tài khoản']
  email_verified boolean [not null, default: false, note: 'Đã xác thực email']
  last_login_at timestamp [note: 'Thời gian đăng nhập gần nhất']

  // Liên kết công ty (Chỉ dành cho Nhà tuyển dụng - role = employer)
  company_id int [note: 'ID công ty liên kết (FK -> companies.id)']

  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo tài khoản']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật gần nhất']

  Note: 'Bảng người dùng hệ thống. Lưu trữ thông tin tài khoản chung và liên kết công ty của Employer.'

  indexes {
    email [unique, name: 'idx_users_email']
    role [name: 'idx_users_role']
    status [name: 'idx_users_status']
    company_id [name: 'idx_users_company']
  }
}

Table candidate_profiles {
  id int [pk, increment, note: 'ID hồ sơ']
  user_id int [unique, not null, note: 'ID người dùng (1-1 với users)']
  title varchar(200) [note: 'Vị trí mong muốn. VD: "React Developer"']
  summary text [note: 'Giới thiệu bản thân']
  date_of_birth date [note: 'Ngày sinh']
  gender varchar(20) [note: 'Giới tính']
  address varchar(255) [note: 'Địa chỉ chi tiết']
  province varchar(100) [note: 'Tỉnh/Thành phố sinh sống (Lưu chuỗi trực tiếp)']
  experience_level varchar(50) [note: 'Cấp bậc kinh nghiệm (fresher, junior...)']
  expected_salary_min decimal(15,2) [note: 'Lương kỳ vọng tối thiểu (VND)']
  expected_salary_max decimal(15,2) [note: 'Lương kỳ vọng tối đa (VND)']
  is_open_to_work boolean [not null, default: true, note: 'Sẵn sàng nhận việc']

  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật']

  Note: 'Hồ sơ chi tiết của ứng viên (role=candidate).'

  indexes {
    user_id [unique, name: 'idx_candidate_profiles_user_id']
    province [name: 'idx_candidate_profiles_province']
  }
}

Table candidate_experiences {
  id int [pk, increment, note: 'ID kinh nghiệm']
  profile_id int [not null, note: 'ID hồ sơ ứng viên (FK -> candidate_profiles.id)']
  company_name varchar(255) [not null, note: 'Tên công ty']
  position varchar(255) [not null, note: 'Vị trí làm việc']
  start_date date [not null, note: 'Ngày bắt đầu']
  end_date date [note: 'Ngày kết thúc']
  description text [note: 'Mô tả chi tiết công việc']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Kinh nghiệm làm việc của ứng viên.'

  indexes {
    profile_id [name: 'idx_candidate_experiences_profile']
  }
}

Table candidate_educations {
  id int [pk, increment, note: 'ID học vấn']
  profile_id int [not null, note: 'ID hồ sơ ứng viên (FK -> candidate_profiles.id)']
  school_name varchar(255) [not null, note: 'Tên trường học/trung tâm']
  major varchar(255) [note: 'Chuyên ngành']
  degree varchar(100) [note: 'Bằng cấp/Chứng chỉ']
  start_date date [not null, note: 'Ngày bắt đầu']
  end_date date [note: 'Ngày kết thúc']
  description text [note: 'Mô tả chi tiết khóa học/quá trình']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Lịch sử học vấn của ứng viên.'

  indexes {
    profile_id [name: 'idx_candidate_educations_profile']
  }
}

Table skills {
  id int [pk, increment, note: 'ID kỹ năng']
  name varchar(100) [unique, not null, note: 'Tên kỹ năng']
  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật']

  Note: 'Danh mục kỹ năng hệ thống (React, NodeJS, Figma...).'

  indexes {
    name [unique, name: 'idx_skills_name']
  }
}

Table candidate_skills {
  id int [pk, increment, note: 'ID kỹ năng ứng viên']
  profile_id int [not null, note: 'ID hồ sơ ứng viên (FK -> candidate_profiles.id)']
  skill_id int [not null, note: 'ID kỹ năng trong danh mục (FK -> skills.id)']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Kỹ năng của ứng viên.'

  indexes {
    profile_id [name: 'idx_candidate_skills_profile']
    skill_id [name: 'idx_candidate_skills_skill']
    (profile_id, skill_id) [unique, name: 'idx_candidate_skills_unique']
  }
}

Table candidate_cvs {
  id int [pk, increment, note: 'ID CV']
  profile_id int [not null, note: 'ID hồ sơ ứng viên (FK -> candidate_profiles.id)']
  cv_url varchar(500) [not null, note: 'Đường dẫn file CV']
  description text [note: 'Mô tả/Ghi chú bản CV']
  is_main boolean [not null, default: false, note: 'Là CV chính']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Danh sách các file CV của ứng viên.'

  indexes {
    profile_id [name: 'idx_candidate_cvs_profile']
    (profile_id, is_main) [name: 'idx_candidate_cvs_main']
  }
}

Table jobs {
  id int [pk, increment, note: 'ID tin tuyển dụng']
  employer_id int [not null, note: 'ID người đăng tin (Nhà tuyển dụng - FK -> users.id)']
  company_id int [not null, note: 'ID công ty tuyển dụng (FK -> companies.id)']
  title varchar(300) [not null, note: 'Tiêu đề tin tuyển dụng']
  slug varchar(300) [unique, not null, note: 'Slug URL-friendly']
  description text [not null, note: 'Mô tả chi tiết công việc']
  requirements text [note: 'Yêu cầu đối với ứng viên']
  benefits text [note: 'Quyền lợi được hưởng']
  industry varchar(150) [note: 'Lĩnh vực/Ngành nghề (Lưu chuỗi trực tiếp)']
  job_type job_type [not null, note: 'Loại hình công việc']
  experience_level varchar(50) [note: 'Yêu cầu kinh nghiệm (fresher, 1-2 năm...)']
  quantity int [not null, default: 1, note: 'Số lượng cần tuyển']
  salary_min decimal(15,2) [note: 'Lương tối thiểu (VND)']
  salary_max decimal(15,2) [note: 'Lương tối đa (VND)']
  is_salary_negotiable boolean [not null, default: false, note: 'Lương thỏa thuận']
  work_address varchar(255) [note: 'Địa chỉ làm việc']
  province varchar(100) [note: 'Tỉnh/Thành phố làm việc (Lưu chuỗi trực tiếp)']



  status job_status [not null, default: 'draft', note: 'Trạng thái tin tuyển dụng']
  is_featured boolean [not null, default: false, note: 'Tin nổi bật']
  is_urgent boolean [not null, default: false, note: 'Tuyển gấp']
  view_count int [not null, default: 0, note: 'Lượt xem tin']
  application_count int [not null, default: 0, note: 'Số đơn ứng tuyển']

  // Thời gian đăng tuyển
  posting_start_at timestamp [not null, default: `now()`, note: 'Thời gian bắt đầu đăng tuyển']
  posting_end_at timestamp [note: 'Thời gian kết thúc đăng tuyển']
  deadline date [note: 'Hạn nộp hồ sơ']
  published_at timestamp [note: 'Ngày công bố tin']

  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật']

  Note: 'Tin tuyển dụng do Employer đăng tuyển thuộc một Company.'

  indexes {
    slug [unique, name: 'idx_jobs_slug']
    employer_id [name: 'idx_jobs_employer']
    company_id [name: 'idx_jobs_company']
    industry [name: 'idx_jobs_industry']
    province [name: 'idx_jobs_province']
    status [name: 'idx_jobs_status']
    deadline [name: 'idx_jobs_deadline']
    posting_start_at [name: 'idx_jobs_posting_start']
    posting_end_at [name: 'idx_jobs_posting_end']
  }
}

Table job_skills {
  id int [pk, increment, note: 'ID kỹ năng tin tuyển dụng']
  job_id int [not null, note: 'ID tin tuyển dụng (FK -> jobs.id)']
  skill_id int [not null, note: 'ID kỹ năng trong danh mục (FK -> skills.id)']
  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật']

  Note: 'Kỹ năng yêu cầu của tin tuyển dụng.'

  indexes {
    job_id [name: 'idx_job_skills_job']
    skill_id [name: 'idx_job_skills_skill']
    (job_id, skill_id) [unique, name: 'idx_job_skills_unique']
  }
}

Table applications {
  id int [pk, increment, note: 'ID đơn ứng tuyển']
  job_id int [not null, note: 'ID tin tuyển dụng']
  candidate_id int [not null, note: 'ID ứng viên (FK -> users.id)']
  cover_letter text [note: 'Thư giới thiệu']

  // CV tại thời điểm nộp (lưu snapshot tránh lỗi khi ứng viên đổi CV chính trong hồ sơ)
  submitted_cv_url varchar(500) [not null, note: 'Đường dẫn file CV khi nộp']
  submitted_cv_name varchar(255) [not null, note: 'Tên file CV khi nộp']

  status application_status [not null, default: 'submitted', note: 'Trạng thái đơn ứng tuyển']
  employer_note text [note: 'Ghi chú nội bộ của nhà tuyển dụng']
  submitted_at timestamp [not null, default: `now()`, note: 'Ngày nộp đơn']
  reviewed_at timestamp [note: 'Ngày xem xét đơn']

  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo']
  updated_at timestamp [not null, default: `now()`, note: 'Ngày cập nhật']

  Note: 'Đơn ứng tuyển của ứng viên nộp vào tin tuyển dụng.'

  indexes {
    (job_id, candidate_id) [unique, name: 'idx_applications_unique']
    job_id [name: 'idx_applications_job']
    candidate_id [name: 'idx_applications_candidate']
    status [name: 'idx_applications_status']
  }
}

Table saved_jobs {
  id int [pk, increment, note: 'ID']
  user_id int [not null, note: 'ID ứng viên (FK -> users.id)']
  job_id int [not null, note: 'ID tin tuyển dụng']
  created_at timestamp [not null, default: `now()`, note: 'Ngày lưu']

  Note: 'Việc làm yêu thích/đã lưu của ứng viên.'

  indexes {
    (user_id, job_id) [unique, name: 'idx_saved_jobs_unique']
    user_id [name: 'idx_saved_jobs_user']
  }
}

Table notifications {
  id int [pk, increment, note: 'ID']
  user_id int [not null, note: 'ID người nhận (FK -> users.id)']
  type notification_type [not null, note: 'Loại thông báo']
  title varchar(255) [not null, note: 'Tiêu đề thông báo']
  content text [note: 'Nội dung chi tiết']
  action_url varchar(500) [note: 'Đường dẫn hành động']
  is_read boolean [not null, default: false, note: 'Đã đọc chưa']
  read_at timestamp [note: 'Thời gian đọc']
  created_at timestamp [not null, default: `now()`, note: 'Ngày tạo']

  Note: 'Thông báo cho người dùng về trạng thái ứng tuyển hoặc hệ thống.'

  indexes {
    user_id [name: 'idx_notifications_user']
    (user_id, is_read) [name: 'idx_notifications_unread']
  }
}

Table user_tokens {
  id int [pk, increment, note: 'ID']
  user_id int [not null, note: 'ID người dùng (FK -> users.id)']
  refresh_token varchar(500) [not null, note: 'Refresh Token làm mới']
  device_id varchar(255) [not null, note: 'Định danh thiết bị đăng nhập']
  expires_at timestamp [not null, note: 'Thời gian hết hạn']

  Note: 'Phiên đăng nhập đa thiết bị phục vụ xác thực JWT.'

  indexes {
    user_id [name: 'idx_user_tokens_user']
    (user_id, device_id) [unique, name: 'idx_user_tokens_user_device']
  }
}

// =============================================
// RELATIONSHIPS DEFINITIONS
// =============================================

// Người dùng → Hồ sơ ứng viên (1-1)
Ref: candidate_profiles.user_id - users.id [delete: cascade]

// Hồ sơ ứng viên → Kinh nghiệm, Học vấn, Kỹ năng (1-N)
Ref: candidate_experiences.profile_id > candidate_profiles.id [delete: cascade]
Ref: candidate_educations.profile_id > candidate_profiles.id [delete: cascade]
Ref: candidate_skills.profile_id > candidate_profiles.id [delete: cascade]
Ref: candidate_skills.skill_id > skills.id [delete: cascade]
Ref: candidate_cvs.profile_id > candidate_profiles.id [delete: cascade]

// Tin tuyển dụng → Nhà tuyển dụng, Công ty & Kỹ năng (N-1 / N-N)
Ref: jobs.employer_id > users.id [delete: cascade]
Ref: jobs.company_id > companies.id [delete: cascade]
Ref: job_skills.job_id > jobs.id [delete: cascade]
Ref: job_skills.skill_id > skills.id [delete: cascade]

// Người dùng (Employer) → Công ty (N-1)
Ref: users.company_id > companies.id [delete: set null]

// Đơn ứng tuyển → Tin tuyển dụng & Ứng viên (N-1)
Ref: applications.job_id > jobs.id [delete: cascade]
Ref: applications.candidate_id > users.id [delete: cascade]

// Lưu tin → Tin tuyển dụng & Ứng viên (N-1)
Ref: saved_jobs.job_id > jobs.id [delete: cascade]
Ref: saved_jobs.user_id > users.id [delete: cascade]

// Thông báo → Người dùng (N-1)
Ref: notifications.user_id > users.id [delete: cascade]

// Token phiên đăng nhập → Người dùng (N-1)
Ref: user_tokens.user_id > users.id [delete: cascade]
