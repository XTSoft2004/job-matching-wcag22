{
  "name": "job-matching-wcag22-root",
  "version": "1.0.0",
  "description": "Monorepo workspace coordinator for JobMatching WCAG 2.2 project",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --prefix apps/backend start:dev",
    "build:backend": "pnpm --prefix apps/backend build",
    "test:backend": "pnpm --prefix apps/backend test",
    "lint:backend": "pnpm --prefix apps/backend lint",
    "dev:ai": "cd apps/ai-tools && .venv\\Scripts\\python -m uvicorn main:app --reload --reload-dir .",
    "install:backend": "pnpm --prefix apps/backend install",
    "seed:backend": "pnpm --prefix apps/backend db:seed",
    "dev:frontend": "pnpm --prefix apps/frontend dev",
    "install:frontend": "pnpm --prefix apps/frontend install",
    "dev:all": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "sync:jobs": "node sync_jobs_vector.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "unrs-resolver",
      "esbuild"
    ]
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}